enum TipoOperadora {
  medica
  odonto
  ambos
}

model OperadoraSaude {
  id          String        @id @default(cuid())
  cnpj        String        @unique
  registroAns String?       @map("registro_ans")
  nome        String?
  tipo        TipoOperadora
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("operadora_saude")
}
