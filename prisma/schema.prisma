//////////////////////////////////////////////////////
// PRESTADOR DE SERVIÇO
//////////////////////////////////////////////////////

model PrestadorServico {
  id String @id @default(cuid())

  empresaId String  @map("empresa_id")
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  cnpj     String // 14 dígitos, sem máscara
  cnpjRaiz String @map("cnpj_raiz")

  razaoSocial  String  @map("razao_social")
  nomeFantasia String? @map("nome_fantasia")

  tipoServico   String? @map("tipo_servico")
  codigoServico String? @map("codigo_servico")

  email    String?
  telefone String?

  ativo Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Vínculos analíticos
  r4020Eventos ReinfR4020[]

  // Vínculos totalizadores (R-2099 — mantido)
  r2099RTom ReinfRTom[]

  @@unique([empresaId, cnpj])
  @@index([cnpj])
  @@index([cnpjRaiz])
  @@map("prestador_servico")
}

//////////////////////////////////////////////////////
// LOTE REINF
//////////////////////////////////////////////////////

model ReinfLote {
  id String @id @default(cuid())

  empresaId String?  @map("empresa_id")
  empresa   Empresa? @relation(fields: [empresaId], references: [id])

  hashArquivo String  @map("hash_arquivo")
  nomeArquivo String? @map("nome_arquivo")
  storagePath String  @map("storage_path")

  totalEventos Int                 @default(0) @map("total_eventos")
  status       StatusProcessamento @default(pendente)
  processadoEm DateTime?           @map("processado_em")
  createdAt    DateTime            @default(now()) @map("created_at")

  eventos ReinfEvento[]

  @@index([hashArquivo])
  @@map("reinf_lote")
}

//////////////////////////////////////////////////////
// EVENTO BASE REINF (R-4020 e R-2099 compartilham)
//////////////////////////////////////////////////////

model ReinfEvento {
  id String @id @default(cuid())

  loteId String?    @map("lote_id")
  lote   ReinfLote? @relation(fields: [loteId], references: [id])

  empresaId String?  @map("empresa_id")
  empresa   Empresa? @relation(fields: [empresaId], references: [id])

  idEvento String @unique @map("id_evento")
  tpEvento String @map("tp_evento") // "R-4020" | "R-2099"
  perApur  String @map("per_apur")

  // Protocolo RFB
  nrRecArqBase String?   @map("nr_rec_arq_base")
  dhRecepcao   DateTime? @map("dh_recepcao")
  dhProcess    DateTime? @map("dh_process")

  // Contribuinte
  cnpjRaiz String? @map("cnpj_raiz")

  // Formato do XML: "evtPgtos" (original) | "evtRet" (recibo)
  formatoXml String @default("evtRet") @map("formato_xml")

  indRetif     Int                 @default(1) @map("ind_retif")
  ativo        Boolean             @default(true)
  status       StatusProcessamento @default(pendente)
  processadoEm DateTime?           @map("processado_em")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  r4020        ReinfR4020Evento?
  r2099        ReinfR2099?
  divergencias ReinfDivergencia[]
  historicos   ReinfEventoHistorico[]

  @@index([empresaId, perApur])
  @@index([cnpjRaiz, perApur])
  @@map("reinf_evento")
}

//////////////////////////////////////////////////////
// HISTÓRICO REINF
//////////////////////////////////////////////////////

model ReinfEventoHistorico {
  id String @id @default(cuid())

  eventoId String      @map("evento_id")
  evento   ReinfEvento @relation(fields: [eventoId], references: [id])

  acao          TipoAcaoHistorico
  descricao     String?
  payloadAntes  Json?             @map("payload_antes")
  payloadDepois Json?             @map("payload_depois")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventoId])
  @@map("reinf_evento_historico")
}

//////////////////////////////////////////////////////
// R-4020 — CABEÇALHO DO EVENTO (1 por ReinfEvento)
//////////////////////////////////////////////////////

model ReinfR4020Evento {
  id String @id @default(cuid())

  eventoId String      @unique @map("evento_id")
  evento   ReinfEvento @relation(fields: [eventoId], references: [id])

  empresaId String?  @map("empresa_id")
  empresa   Empresa? @relation(fields: [empresaId], references: [id])

  perApur String @map("per_apur")

  // CNPJ completo do estabelecimento tomador (nrInsc do ideEstab)
  cnpjEstab String @map("cnpj_estab")

  createdAt DateTime @default(now()) @map("created_at")

  // Registros analíticos por prestador
  registros ReinfR4020[]

  @@index([empresaId, perApur])
  @@map("reinf_r4020_evento")
}

//////////////////////////////////////////////////////
// R-4020 — REGISTRO POR BENEFICIÁRIO/PRESTADOR
// Um ReinfR4020Evento → N ReinfR4020 (um por nrInscBenef)
//////////////////////////////////////////////////////

model ReinfR4020 {
  id String @id @default(cuid())

  r4020EventoId String           @map("r4020_evento_id")
  r4020Evento   ReinfR4020Evento @relation(fields: [r4020EventoId], references: [id])

  // Vínculo com cadastro (pode ser null → gera divergência)
  prestadorId String?           @map("prestador_id")
  prestador   PrestadorServico? @relation(fields: [prestadorId], references: [id])

  // CNPJ do beneficiário (prestador de serviço)
  cnpjBenef String @map("cnpj_benef")

  createdAt DateTime @default(now()) @map("created_at")

  // Retenções por CRMen (1:N — um prestador pode ter múltiplos CRMen)
  retencoescrMen ReinfR4020CRMen[]

  @@index([cnpjBenef])
  @@map("reinf_r4020")
}

//////////////////////////////////////////////////////
// R-4020 — RETENÇÃO POR CRMen (totApurMen)
// Este é o nível atômico da auditoria fiscal REINF.
// Um ReinfR4020 → N ReinfR4020CRMen
//////////////////////////////////////////////////////

model ReinfR4020CRMen {
  id String @id @default(cuid())

  r4020Id String     @map("r4020_id")
  r4020   ReinfR4020 @relation(fields: [r4020Id], references: [id])

  // CRMen: NUNCA descartar, NUNCA substituir por texto — persistir exato do XML
  crMen String @map("cr_men")

  // Base de cálculo e valor retido
  vlrBaseCRMen Decimal @map("vlr_base_cr_men") @db.Decimal(14, 2)
  vlrCRMenInf  Decimal @map("vlr_cr_men_inf") @db.Decimal(14, 2)

  // Natureza do rendimento (código da tabela REINF)
  natRend String? @map("nat_rend")

  // Valor em suspensão (quando há discussão judicial)
  vlrCRMenSusp Decimal @default(0) @map("vlr_cr_men_susp") @db.Decimal(14, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([crMen])
  @@map("reinf_r4020_cr_men")
}

//////////////////////////////////////////////////////
// R-2099 — TOTALIZADOR OFICIAL (mantido integralmente)
//////////////////////////////////////////////////////

model ReinfR2099 {
  id String @id @default(cuid())

  eventoId String      @unique @map("evento_id")
  evento   ReinfEvento @relation(fields: [eventoId], references: [id])

  empresaId String?  @map("empresa_id")
  empresa   Empresa? @relation(fields: [empresaId], references: [id])

  perApur         String  @map("per_apur")
  indExistInfo    Int?    @map("ind_exist_info")
  identEscritDCTF String? @map("ident_escrit_dctf")

  createdAt DateTime @default(now()) @map("created_at")

  retencoesTomador ReinfRTom[]

  @@index([empresaId, perApur])
  @@map("reinf_r2099")
}

//////////////////////////////////////////////////////
// R-2099 — RETENÇÃO POR TOMADOR (RTom)
//////////////////////////////////////////////////////

model ReinfRTom {
  id String @id @default(cuid())

  r2099Id String     @map("r2099_id")
  r2099   ReinfR2099 @relation(fields: [r2099Id], references: [id])

  prestadorId String?           @map("prestador_id")
  prestador   PrestadorServico? @relation(fields: [prestadorId], references: [id])

  cnpjPrestador   String  @map("cnpj_prestador")
  vlrTotalBaseRet Decimal @map("vlr_total_base_ret") @db.Decimal(14, 2)

  createdAt DateTime @default(now()) @map("created_at")

  codigosReceita ReinfCRTom[]

  @@index([cnpjPrestador])
  @@map("reinf_rtom")
}

//////////////////////////////////////////////////////
// R-2099 — CÓDIGO DE RECEITA POR TOMADOR
//////////////////////////////////////////////////////

model ReinfCRTom {
  id String @id @default(cuid())

  rTomId String    @map("rtom_id")
  rTom   ReinfRTom @relation(fields: [rTomId], references: [id])

  crTom        String  @map("cr_tom")
  vlrCRTom     Decimal @map("vlr_cr_tom") @db.Decimal(14, 2)
  vlrCRTomSusp Decimal @default(0) @map("vlr_cr_tom_susp") @db.Decimal(14, 2)

  @@map("reinf_cr_tom")
}

