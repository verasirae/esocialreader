//////////////////////////////////////////////////////
// MÓDULO DE CONSULTAS ESPECIAIS
//////////////////////////////////////////////////////

model ConsultaEspecial {
  id            String    @id @default(cuid())

  titulo        String
  descricao     String?

  // "sql_livre" | "visual"
  tipo          String    @default("sql_livre")

  // SQL final persistido (gerado pelo editor ou pelo builder)
  sqlTexto      String    @map("sql_texto") @db.Text

  // Parâmetros do builder visual (JSON com filtros configurados)
  parametros    Json?

  // Controle
  criadoPor     String    @map("criado_por")   // userId do SuperAdmin
  ativo         Boolean   @default(true)
  favorito      Boolean   @default(false)

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  execucoes     ConsultaExecucao[]

  @@map("consulta_especial")
}

model ConsultaExecucao {
  id              String            @id @default(cuid())

  consultaId      String?           @map("consulta_id")
  consulta        ConsultaEspecial? @relation(fields: [consultaId], references: [id])

  // SQL exato que foi executado (pode diferir do salvo se editado ad-hoc)
  sqlExecutado    String            @map("sql_executado") @db.Text

  // Resultado resumido para log (nunca salvar dados sensíveis aqui)
  totalLinhas     Int               @default(0) @map("total_linhas")
  duracaoMs       Int               @default(0) @map("duracao_ms")

  // "sucesso" | "erro" | "timeout" | "bloqueado"
  status          String            @default("sucesso")
  mensagemErro    String?           @map("mensagem_erro") @db.Text

  executadoPor    String            @map("executado_por")

  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([consultaId])
  @@index([executadoPor])
  @@map("consulta_execucao")
}

//////////////////////////////////////////////////////
// TABELA: CÓDIGOS DE RECEITA RFB
//////////////////////////////////////////////////////

model RfbCodigoReceita {
  id           String   @id @default(cuid())

  codigo       String   @unique           // ex: "0561", "116201"
  denominacao  String   @db.Text

  // Array de bases legais (portarias, ADEs, INs)
  baseLegal    String[] @map("base_legal")

  dtCriacao    DateTime? @map("dt_criacao")  @db.Date
  dtExtincao   DateTime? @map("dt_extincao") @db.Date

  // Ativo = não possui dt_extincao ou dt_extincao está no futuro
  ativo        Boolean  @default(true)

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([ativo])
  @@map("rfb_codigo_receita")
}

