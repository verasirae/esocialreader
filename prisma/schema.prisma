model EsocialTabela54 {
  id              String    @id @default(cuid())
  codRubrica      String    @map("cod_rubrica")
  nomeRubrica     String?   @map("nome_rubrica")
  dtInicio        DateTime  @map("dt_inicio")
  dtFim           DateTime? @map("dt_fim")
  natRubrica      String?   @map("nat_rubrica")
  tipoRubrica     String?   @map("tipo_rubrica")
  codIncCp        String?   @map("cod_inc_cp")
  codIncIrrf      String?   @map("cod_inc_irrf")
  codIncFgts      String?   @map("cod_inc_fgts")
  codIncSind      String?   @map("cod_inc_sind")
  repDsr          String?   @map("rep_dsr")
  rep13           String?   @map("rep_13")
  repFerias       String?   @map("rep_ferias")
  repResc         String?   @map("rep_resc")
  repAfast        String?   @map("rep_afast")
  fatorRubr       String?   @map("fator_rubr")
  localAplic      String?   @map("local_aplic")
  domestica       String?   @map("domestica")
  se              String?   @map("se")
  geral           String?   @map("geral")
  descricao       String?   @map("descricao")
  nota            String?   @map("nota")
  ordRescDom      String?   @map("ord_resc_dom")
  perAdicRub      String?   @map("per_adic_rub")
  ordRemDom       String?   @map("ord_rem_dom")
  repSfDom        String?   @map("rep_sf_dom")
  perFolRes       String?   @map("per_fol_res")
  perEditRub      String?   @map("per_edit_rub")
  perExcRub       String?   @map("per_exc_rub")
  filCatRub       String?   @map("fil_cat_rub")
  grupRendDom     String?   @map("grup_rend_dom")
  codIncCprp      String?   @map("cod_inc_cprp")
  codIncPisPasep  String?   @map("cod_inc_pis_pasep")
  rdConsignado    String?   @map("rd_consignado")

  @@unique([codRubrica, dtInicio])
  @@map("esocial_tabela_54")
}

